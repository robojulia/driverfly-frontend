BASE_URL=http://localhost:4000
BASE_URL_API=http://localhost:4000/api

FRONTEND_BASE_URL=http://localhost:3000

MAPBOX_API_KEY=""

TWILIO_APP_NAME="driverfly"

PHONE_INPUT_COUNTRY_ALLOWED=us,pk

RECAPTCHA_SITE_KEY=""

NEXT_PUBLIC_MICROSOFT_CLARITY=""

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Stripe Price IDs (get these from Stripe Dashboard after creating products)
STRIPE_PRICE_BASIC_MONTHLY=price_xxxxx
STRIPE_PRICE_BASIC_ANNUAL=price_xxxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxxx
STRIPE_PRICE_PRO_ANNUAL=price_xxxxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxxxx
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_xxxxx

# Facebook Lead Ads Integration
# Must match FB_VERIFY_TOKEN in the backend
FACEBOOK_WEBHOOK_VERIFY_TOKEN=
# App Secret from the Facebook App Dashboard (Settings → Basic)
# Used to verify HMAC-SHA256 webhook payload signatures
FACEBOOK_APP_SECRET=
# Service-to-service bearer token for Next.js → backend API calls
# Must match the value expected by the DriverFly backend
BACKEND_SERVICE_TOKEN=

# Indeed Job Sync API (2-legged OAuth)
# Obtain credentials from https://partners.indeed.com
INDEED_CLIENT_ID=
INDEED_CLIENT_SECRET=
# Unique feed identifier registered with Indeed for this employer
INDEED_SOURCE_NAME=DriverFlyFeed

# Anthropic Claude AI (for AI Note Log)
ANTHROPIC_API_KEY=