{
  "compilerOptions": {
    "target": "es2015"  ,
      "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "pages/dashboard/_middleware.js",
    "pages/dashboard/dashboard.js",
    "components/BaseInput.js"
  ],
  "exclude": [
    "node_modules"
  ]
  //  "incremental": true

}
