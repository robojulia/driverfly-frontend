{
  "routes": [
    {
      "route": "/api/*",
      "serve": "/api/*",
      "statusCode": 200
    },
    {
      "route": "/_next/static/*",
      "serve": "/_next/static/*",
      "statusCode": 200,
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/_next/*",
      "serve": "/_next/*",
      "statusCode": 200
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/images/*", 
      "/css/*", 
      "/js/*", 
      "/api/*", 
      "/_next/*",
      "/*.ico", 
      "/*.json", 
      "/*.png", 
      "/*.jpg", 
      "/*.jpeg", 
      "/*.gif", 
      "/*.svg",
      "/*.woff",
      "/*.woff2",
      "/*.ttf",
      "/*.eot"
    ]
  },
  "platform": {
    "apiRuntime": "node:20"
  },
  "trailingSlash": "auto"
} 